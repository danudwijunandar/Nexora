<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Nexora1" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Picker themes -->
        <item name="android:datePickerDialogTheme">@style/CustomPickerTheme</item>
        <item name="android:timePickerDialogTheme">@style/CustomPickerTheme</item>
    </style>

    <style name="CustomPickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorPrimary</item>
        <!-- Mengatur warna teks tombol positif (OK) dan negatif (Batal) -->
        <item name="android:buttonBarPositiveButtonStyle">@style/PickerButtonStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/PickerButtonStyle</item>
    </style>

    <style name="PickerButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/black</item>
    </style>
</resources>