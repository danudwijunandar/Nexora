<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring" android:thickness="6dp" android:useLevel="false">
            <solid android:color="#335CEEF6"/>
        </shape>
    </item>
    <item>
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:shape="ring" android:thickness="6dp" android:useLevel="true">
                <gradient android:startColor="#00E2FB" android:endColor="#27F6E1" android:type="sweep" />
            </shape>
        </rotate>
    </item>
</layer-list>